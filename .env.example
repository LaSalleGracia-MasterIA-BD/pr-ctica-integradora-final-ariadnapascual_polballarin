# PostgreSQL (estructurados: pacientes, ingresos, personal, logs)
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me
POSTGRES_DB=hospital
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# MongoDB (no estructurados: radiografías GridFS, predicciones, informes, eventos)
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=change-me
MONGO_DB=hospital
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_GRIDFS_BUCKET=radiographs

# API
API_PORT=8005
API_LOG_LEVEL=INFO

# Dashboard
DASHBOARD_PORT=8502

# ML radiografías (SDD-06)
ML_MODEL_PATH=/app/models/resnet50_covid.pt
ML_DEVICE=cpu

# ML triaje tabular (SDD-08) — path al directorio del artefacto o al marker 'current'
ML_TRIAGE_MODEL_PATH=/app/models/triage/current

# ML sospecha de enfermedad (DESIGN-08b) — segundo modelo del servicio ml-triage
ML_DISEASE_MODEL_PATH=/app/models/disease/current

# Admin UIs
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change-me

# MinIO — servidor S3-compatible que almacena la capa raw (patrón landing zone).
# El protocolo S3 es un estándar abierto; si algún día se usa otro backend
# S3-compatible, basta con cambiar S3_ENDPOINT y las credenciales.
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=change-me
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Cliente S3 (boto3). Apunta al servidor MinIO definido arriba.
# S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY deben coincidir con MINIO_ROOT_*.
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET_RAW=hospital-raw
S3_ACCESS_KEY_ID=admin
S3_SECRET_ACCESS_KEY=change-me


# Dask — motor escalable para procesamiento batch del pipeline
PIPELINE_PROCESSING_ENGINE=dask
DASK_SCHEDULER_ADDRESS=tcp://dask-scheduler:8786
DASK_DASHBOARD_PORT=8787
DASK_WORKERS=1
DASK_THREADS_PER_WORKER=2
DASK_WORKER_MEMORY=1GB
DASK_CSV_BLOCKSIZE=16MB

ML_INFERENCE_URL=http://ml-inference:8001